{
  "name": "detemiro-spa-workspace",
  "version": "1.0.0",
  "description": "The generic FE blueprint.",
  "main": "index.js",
  "repository": "https://github.com/RuBAN-GT/detemiro-spa-blueprint",
  "author": "Dmitry Ruban",
  "license": "MIT",
  "private": true,
  "packageManager": "yarn@4.16.0",
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "build": "yarn workspace detemiro-spa-app build",
    "start": "yarn workspace detemiro-spa-app start:prod",
    "start:dev": "yarn workspace detemiro-spa-app start:dev",
    "lint": "yarn workspaces foreach --all run lint",
    "heroku-postbuild": "yarn build && yarn workspaces focus --all --production",
    "postinstall": "husky || true",
    "prepack": "pinst --disable",
    "postpack": "pinst --enable"
  },
  "devDependencies": {
    "@commitlint/cli": "18.6.1",
    "@commitlint/config-conventional": "18.6.3",
    "@commitlint/types": "18.6.1",
    "@eslint/js": "^9.39.4",
    "@innocells/branch-naming-check": "^1.0.0",
    "@types/node": "^22.15.0",
    "commitlint-plugin-regex-match": "^1.2.4",
    "eslint": "^9.39.4",
    "eslint-config-detemiro": "^2.1.0",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-project-structure": "^3.14.3",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^15.15.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "pinst": "^3.0.0",
    "prettier": "^3.8.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.0"
  },
  "resolutions": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "~19.2.3"
  }
}
