{
  "extends": "@modern-js/tsconfig/base",
  "include": ["src", "shared", "config", "modern.config.ts"],
  "exclude": ["**/node_modules"],
  "compilerOptions": {
    "declaration": false,
    "jsx": "preserve",
    "baseUrl": "./",
    "paths": {
      "~/*": ["./src/*"],
      "~shared/*": ["./shared/*"]
    }
  }
}
